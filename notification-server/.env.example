# ─────────────────────────────────────────────────────────────
# CallingApp Notification Server — environment variables
# ─────────────────────────────────────────────────────────────

# REQUIRED — Firebase Admin (one of the two)
# Paste FULL service-account JSON as a single-line string (escape inner quotes)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"call-9d7b8","...":"..."}
# OR set GOOGLE_APPLICATION_CREDENTIALS to a path to the JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/service-account.json

# REQUIRED — Realtime DB URL
FIREBASE_DATABASE_URL=https://call-9d7b8-default-rtdb.asia-southeast1.firebasedatabase.app

# RECOMMENDED — protect /api/send & admin endpoints
SERVER_API_KEY=change-me-to-a-long-random-string

# Per-user send rate-limit (sends per minute)
RATE_LIMIT_PER_MIN=30

# Render sets PORT automatically; locally default 8080
PORT=8080
NODE_ENV=production

# ─────────────────────────────────────────────────────────────
# Cloudinary — media storage (signed uploads)
# Cloud name: dvqqgqdls
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=dvqqgqdls
CLOUDINARY_API_KEY=344887545754427
CLOUDINARY_API_SECRET=krFxU3B6UmpRRigEm2EPNJxkdps
# Folder prefix used for all uploads (helps organize the media library)
CLOUDINARY_UPLOAD_FOLDER=callingapp
# Max upload size in MB (server-side enforced via signing)
CLOUDINARY_MAX_FILE_MB=50
